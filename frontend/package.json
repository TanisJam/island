{
  "name": "isla-misteriosa-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.0",
  "description": "Cliente web mínimo de referencia de Isla Misteriosa (MVP). Vite vanilla-ts + Canvas 2D.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tool": "tsc -p tsconfig.tool.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"tools/**/*.test.ts\"",
    "sync:contract": "cp ../schemas/generated/*.ts src/contract/",
    "sync:catalog": "mkdir -p tools/atlas-editor/catalog && cp ../catalog/*.json tools/atlas-editor/catalog/",
    "dev:tool": "pnpm sync:catalog && vite --config vite.config.tool.ts",
    "build:tool": "pnpm sync:catalog && vite build --config vite.config.tool.ts",
    "sync:catalog:items": "mkdir -p tools/items-editor/catalog && cp ../catalog/*.json tools/items-editor/catalog/",
    "sync:schemas:items": "mkdir -p tools/items-editor/schemas && cp ../schemas/common.json ../schemas/catalog.json tools/items-editor/schemas/",
    "dev:tool:items": "pnpm sync:catalog:items && pnpm sync:schemas:items && vite --config vite.config.items-editor.ts",
    "build:tool:items": "pnpm sync:catalog:items && pnpm sync:schemas:items && vite build --config vite.config.items-editor.ts"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "ajv": "^8.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.10"
  }
}
